utils_config = """\"\"\"
Configuration Management
\"\"\"

import yaml
import os
from pathlib import Path
from typing import Dict, Any
from dataclasses import dataclass, field


@dataclass
class ModelConfig:
    architecture: str = "resnet50"
    num_classes: int = 10
    pretrained: bool = True
    dropout: float = 0.5
    freeze_backbone: bool = False
    img_size: int = 224

@dataclass
class TrainingConfig:
    epochs: int = 100
    batch_size: int = 32
    learning_rate: float = 1e-3
    weight_decay: float = 1e-4
    scheduler: str = "cosine"
    label_smoothing: float = 0.1
    mixed_precision: bool = True
    early_stopping_patience: int = 10
    gradient_clip: float = 1.0

@dataclass
class DataConfig:
    train_dir: str = "data/train"
    val_dir: str = "data/val"
    test_dir: str = "data/test"
    num_workers: int = 4
    pin_memory: bool = True

@dataclass
class Config:
    model: ModelConfig = field(default_factory=ModelConfig)
    training: TrainingConfig = field(default_factory=TrainingConfig)
    data: DataConfig = field(default_factory=DataConfig)
    seed: int = 42
    experiment_name: str = "cnn-classifier"
    checkpoint_dir: str = "checkpoints"
    log_dir: str = "logs"


class ConfigManager:
    \"\"\"Manage configuration from files and environment variables\"\"\"
    
    @staticmethod
    def load_yaml(path: str) -> Dict[str, Any]:
        with open(path) as f:
            return yaml.safe_load(f)
    
    @staticmethod
    def save_yaml(config: Dict[str, Any], path: str):
        Path(path).parent.mkdir(parents=True, exist_ok=True)
        with open(path, 'w') as f:
            yaml.dump(config, f, default_flow_style=False)
    
    @staticmethod
    def from_dict(config_dict: Dict[str, Any]) -> Config:
        \"\"\"Create Config from dictionary\"\"\"
        return Config(
            model=ModelConfig(**config_dict.get('model', {})),
            training=TrainingConfig(**config_dict.get('training', {})),
            data=DataConfig(**config_dict.get('data', {})),
            seed=config_dict.get('seed', 42),
            experiment_name=config_dict.get('experiment_name', 'cnn-classifier'),
            checkpoint_dir=config_dict.get('checkpoint_dir', 'checkpoints'),
            log_dir=config_dict.get('log_dir', 'logs')
        )
    
    @staticmethod
    def override_from_env(config: Config) -> Config:
        \"\"\"Override config with environment variables\"\"\"
        if os.getenv('MODEL_ARCHITECTURE'):
            config.model.architecture = os.getenv('MODEL_ARCHITECTURE')
        if os.getenv('BATCH_SIZE'):
            config.training.batch_size = int(os.getenv('BATCH_SIZE'))
        if os.getenv('LEARNING_RATE'):
            config.training.learning_rate = float(os.getenv('LEARNING_RATE'))
        if os.getenv('EPOCHS'):
            config.training.epochs = int(os.getenv('EPOCHS'))
        return config
