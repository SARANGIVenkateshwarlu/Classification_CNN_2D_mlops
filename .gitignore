# =============================================================================
# Solar Panel Classifier — Comprehensive .gitignore
# =============================================================================

# ---------------------------------------------------------------------------
# Python
# ---------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST
.pytest_cache/
.mypy_cache/
.dmypy.json
.ruff_cache/

# ---------------------------------------------------------------------------
# Virtual Environments
# ---------------------------------------------------------------------------
.venv/
venv/
ENV/
env/
env.bak/
venv.bak/

# ---------------------------------------------------------------------------
# Environment Variables & Secrets (NEVER commit these!)
# ---------------------------------------------------------------------------
.env
.env.local
.env.*.local
.env.development
.env.test
.env.production
secrets.yaml
secrets.yml
secrets.json
*.pem
*.key
*.crt
*.pfx
*.p12

# ---------------------------------------------------------------------------
# AWS
# ---------------------------------------------------------------------------
.aws/credentials
.aws/config
.terraform/
terraform.tfstate
terraform.tfstate.*.backup
terraform.tfstate.backup
.terraform.lock.hcl
.terraformrc
terraform.rc
*.tfvars
*.tfvars.json
override.tf
override.tf.json
*_override.tf
*_override.tf.json
crash.log
crash.*.log
terraform-provider-*

# ---------------------------------------------------------------------------
# Docker
# ---------------------------------------------------------------------------
*.pid
*.seed
*.pid.lock
.dockerignore.backup
docker-compose.override.yml
docker-compose.override.yaml

# ---------------------------------------------------------------------------
# Kubernetes
# ---------------------------------------------------------------------------
kubeconfig
*.kubeconfig
.kube/
k8s/**/secrets*.yaml
k8s/**/secrets*.yml

# ---------------------------------------------------------------------------
# Jupyter / IPython
# ---------------------------------------------------------------------------
.ipynb_checkpoints/
*.ipynb_checkpoints
profile_default/
ipython_config.py

# ---------------------------------------------------------------------------
# Data & Large Artifacts (handled via DVC / S3 / external storage)
# ---------------------------------------------------------------------------
Data/
data/
datasets/
models/*.h5
models/*.keras
models/*.pb
models/*.onnx
models/*.tflite
models/*.savedmodel/
!models/.gitkeep

# Keras Tuner artifacts
kt_dir/

# MLflow
mlruns/
mlartifacts/

# DVC
.dvc
.dvcignore

# ---------------------------------------------------------------------------
# Testing & Coverage
# ---------------------------------------------------------------------------
.pytest_cache/
.coverage
.coverage.*
htmlcov/
.tox/
nosetests.xml
coverage.xml
*.cover
*.py,cover
.hypothesis/

# ---------------------------------------------------------------------------
# IDEs & Editors
# ---------------------------------------------------------------------------
.vscode/
.idea/
*.swp
*.swo
*~
*.sublime-project
*.sublime-workspace
.project
.classpath
.c9/
*.launch
.settings/
*.tmproj
*.esproj
nbproject/

# ---------------------------------------------------------------------------
# OS Generated Files
# ---------------------------------------------------------------------------
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# ---------------------------------------------------------------------------
# Logs & Temporary Files
# ---------------------------------------------------------------------------
*.log
logs/
log/
_temp_*
*.tmp
*.temp
tmp/
temp/
*.bak
*.backup
*.orig
*.rej

# ---------------------------------------------------------------------------
# Archives
# ---------------------------------------------------------------------------
*.zip
*.tar
*.tar.gz
*.tgz
*.rar
*.7z

# ---------------------------------------------------------------------------
# Build & Distribution Artifacts
# ---------------------------------------------------------------------------
lambda-layer.zip
lambda-function.zip
solar-panel-app.zip
*.whl

# ---------------------------------------------------------------------------
# Node (if frontend added later)
# ---------------------------------------------------------------------------
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ---------------------------------------------------------------------------
# Misc
# ---------------------------------------------------------------------------
solar-panel-policy.json
ec2-trust-policy.json
ecs-trust-policy.json
lambda-trust-policy.json
